# The private Codex bridge already running beside n8n.
CODEX_AGENT_URL=http://codex-agent:8080

# Docker network currently shared by n8n and codex-agent.
CODEX_NETWORK=n8n_default

# Local development only. Docker writes to /data/9n9.db.
N9N_DATABASE_PATH=./data/9n9.db

# Generate once with: openssl rand -base64 32
# Keep this outside SQLite and never commit the real value.
N9N_MASTER_KEY=

# Optional non-interactive first admin. Omit for the setup screen.
N9N_BOOTSTRAP_ADMIN_USERNAME=admin
N9N_BOOTSTRAP_ADMIN_PASSWORD=

# Exact browser origin when running behind a proxy.
N9N_PUBLIC_ORIGIN=http://192.168.1.95:9999

# Optional additional boundary for a LAN-only deployment.
N9N_TRUSTED_LAN_ONLY=false
